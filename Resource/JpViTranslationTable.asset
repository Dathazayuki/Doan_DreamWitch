  - japanese: "\u81EA\u5F8B\u9B54\u5C0E\u66F8\u306E\u653B\u6483\u983B\u5EA6\u304C\u5897\u52A0\u3057\u3001\u5C5E\u6027\u5024\u309220\u4ED8\u4E0E"
