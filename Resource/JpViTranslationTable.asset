  - japanese: "\u9B54\u5C0E\u66F8\u53D6\u5F97\u6642\u306B\u81EA\u52D5\u3067\u653B\u6483\u3092\u884C\u3046\u81EA\u5F8B\u9B54\u5C0E\u66F8\u3092\uFF11\u3064\u53EC\u559A\u3059\u308B\u3002\u540C\u3058\u8272\u306E\u81EA\u5F8B\u9B54\u5C0E\u66F8\u306F\uFF11\u3064\u307E\u3067\u6240\u6301\u53EF\u80FD"
